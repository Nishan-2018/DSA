class Solution {
public:
    int longestConsecutive(vector<int>& nums) {
        
        if(nums.size() == 0) return 0;

        sort(nums.begin(), nums.end());

        int longest = 1;
        int cnt = 1;

        for(int i = 1; i < nums.size(); i++) {

            // Skip duplicates
            if(nums[i] == nums[i - 1]) {
                continue;
            }

            // Consecutive number
            if(nums[i] == nums[i - 1] + 1) {
                cnt++;
            }
            else {
                longest = max(longest, cnt);
                cnt = 1;
            }
        }

        longest = max(longest, cnt);

        return longest;
    }
};
