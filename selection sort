class Solution {
public:
    vector<int> selectionSort(vector<int>& nums) {
        int size=nums.size();
        for(int i=0;i<size-1;i++)
        {
            int min=i;
            for(int j=i+1;j<size;j++)
            {
                if(nums[j]<nums[min])
                {
                    min=j;
                }
            }
            swap(nums[i],nums[min]);
        }
        return nums;



    }
};
