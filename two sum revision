class Solution {
public:
    vector<int> twoSum(vector<int>& nums, int target) {
        int n=nums.size();
        unordered_map<int,int> ans;
        for(int i=0;i<n;i++)
        {
            int reminder=target-nums[i];
            if(ans.find(reminder)!=ans.end())
            {
                return {ans[reminder],i};
            }
            ans[nums[i]]=i;
        }
        return {};

        
    }
};
